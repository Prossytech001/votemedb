generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  passwordHash  String
  walletBalance Decimal       @default(0) @db.Decimal(12, 2)
  createdAt     DateTime      @default(now())
  orders        Order[]
  transactions  Transaction[]
}

model Order {
  id          String   @id @default(cuid())
  user        User     @relation(fields: [userId], references: [id])
  userId      String
  provider    String   @default("5sim")
  providerId  String   // 5sim order id
  service     String   // whatsapp, telegram, instagram...
  country     String
  number      String
  price       Decimal  @db.Decimal(12, 2)
  status      OrderStatus @default(waiting)
  otpCode     String?
  createdAt   DateTime @default(now())
  expiresAt   DateTime
}

enum OrderStatus {
  waiting
  received
  expired
  cancelled
}

model Transaction {
  id            String   @id @default(cuid())
  user          User     @relation(fields: [userId], references: [id])
  userId        String
  type          TxType
  amount        Decimal  @db.Decimal(12, 2)
  balanceAfter  Decimal  @db.Decimal(12, 2)
  reference     String   @unique
  createdAt     DateTime @default(now())
}

enum TxType {
  deposit
  purchase
  refund
}

model NumberPool {
  id         String   @id @default(cuid())
  provider   String
  country    String
  service    String
  costPrice  Decimal  @db.Decimal(12, 2)
  sellPrice  Decimal  @db.Decimal(12, 2)
  updatedAt  DateTime @updatedAt
}
